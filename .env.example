# Credit Approval System - Production Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyası asla versiyon kontrolüne eklenmemelidir.

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL Veritabanı
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/credit_approval_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<güvenli-şifre-buraya>

# Sunucu (opsiyonel)
SERVER_PORT=8080

# Logging (opsiyonel)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_CREDITAPP=INFO
